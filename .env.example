# =============================================================================
# APICenter — Environment Variables
# =============================================================================
# Copy to .env:  cp .env.example .env
#
# These variables are read by all 3 gateway containers (they share the same
# env_file in docker-compose.yml). There are no container-specific overrides —
# the gateway is fully stateless and all containers are identical.
#
# CORS:
#   ALLOWED_ORIGINS controls which browser origins receive
#   Access-Control-Allow-Origin. Set * for local dev.
#   In production use a comma-separated list of allowed origins.
#   NGINX nginx.conf uses the same list for preflight handling.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS (required) ───────────────────────────────────────────────────────────
# Dev:  ALLOWED_ORIGINS=*
# Prod: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# ── Auth Provider ─────────────────────────────────────────────────────────────
# dev-jwt  = ephemeral RS256 key, no external IdP needed (default for local dev)
# keycloak = production OIDC/JWKS via Keycloak
# google   = Google OAuth2 / OIDC (user login + service-account M2M)
AUTH_PROVIDER=dev-jwt

DEV_JWT_ISSUER=api-center-dev
DEV_JWT_TTL_SECONDS=3600
DEV_JWT_REFRESH_TTL_MULTIPLIER=24

# Optional: stable RSA key pair for DevJwtProvider (tokens survive restarts)
# Generate: openssl genrsa 2048 > private.pem && openssl rsa -in private.pem -pubout > public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Google OAuth2 / OIDC (AUTH_PROVIDER=google only) ─────────────────────────
# Setup: https://console.cloud.google.com/apis/credentials
#   1. Create Project (if needed)
#   2. APIs & Services → Credentials → Create Credentials → OAuth client ID
#   3. Application type: Web application
#   4. Authorized redirect URIs: http://localhost:3000/api/v1/auth/google/callback
#   5. Copy Client ID and Client Secret below
#
# For user auth (browser login):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI registered in Google Cloud Console (must match exactly)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
# Restrict to specific Google Workspace domains (comma-separated), or leave empty for all
# Example: GOOGLE_ALLOWED_DOMAINS=yourcompany.com,partner.com
GOOGLE_ALLOWED_DOMAINS=
#
# For M2M service-account auth (tribe services):
# Base64-encode each service account JSON key:
#   base64 -w0 service-account-key.json
# Then set: GOOGLE_SA_KEY_<SERVICE_ID_UPPER>=<base64-encoded-json>
# Example:
# GOOGLE_SA_KEY_PAYMENT_SERVICE=<base64-encoded-json>
# GOOGLE_SA_KEY_USER_SERVICE=<base64-encoded-json>

# ── Keycloak (AUTH_PROVIDER=keycloak only) ────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=api-center
KEYCLOAK_JWKS_URI=
KEYCLOAK_TOKEN_ENDPOINT=
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=
KEYCLOAK_REFRESH_CLIENT_ID=api-center
KEYCLOAK_DEFAULT_CLIENT_SECRET=
# Set true ONLY when behind a trusted Envoy/Ingress that pre-verifies JWTs
ENVOY_TRUST_HEADERS=false

# ── GCP Secret Manager ───────────────────────────────────────────────────────
# Set GCP_SECRET_NAME to load a JSON secret at startup and merge its keys
# into process.env (existing env vars are NOT overridden).
# Leave unset for local development — process.env is used directly.
#
# GCP_SECRET_NAME      Name of the secret in GCP Secret Manager (required to enable)
# GCP_PROJECT_ID       GCP project that owns the secret
#                      (falls back to GOOGLE_CLOUD_PROJECT if unset)
# GCP_SECRET_VERSION   Version to fetch (default: latest)
#
GCP_SECRET_NAME=
GCP_PROJECT_ID=
# GCP_SECRET_VERSION=latest

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
# Dev mode: no unsealing, root token (local only — never in production)
VAULT_DEV_MODE=true
VAULT_TOKEN=root
# AppRole (production): use these instead of VAULT_TOKEN
VAULT_ROLE_ID=
VAULT_SECRET_ID=
VAULT_SECRET_PATH=secret/api-center/dev
# Transit key for server-side signing (leave empty to use local key)
VAULT_TRANSIT_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Both URLs override the docker-compose default env block — leave blank to
# use the docker-compose defaults (redis-cache:6379 / redis-rate-limit:6379).
REDIS_CACHE_URL=redis://localhost:6381
REDIS_RATE_LIMIT_URL=redis://localhost:6380
REDIS_TOKEN_TTL_SECONDS=3600
REDIS_SESSION_TTL_SECONDS=86400

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=api-center
KAFKA_GROUP_ID=api-center-group

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Observability ─────────────────────────────────────────────────────────────
JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_SERVICE_NAME=api-center

# ── Platform admin ────────────────────────────────────────────────────────────
# Required in production. Generate: openssl rand -hex 32
PLATFORM_ADMIN_SECRET=change-me-in-production

# ── Per-service secrets ───────────────────────────────────────────────────────
# Format: TRIBE_SECRET_<SERVICE_ID_UPPER_SNAKE>=<sha256-of-actual-secret>
# Hash:   echo -n "my-secret" | sha256sum
# TRIBE_SECRET_USER_SERVICE=<sha256hash>
# TRIBE_SECRET_EMAIL_SERVICE=<sha256hash>
# TRIBE_SECRET_PAYMENT_SERVICE=<sha256hash>

# ── External APIs ─────────────────────────────────────────────────────────────
GEOLOCATION_API_URL=https://api.ipgeolocation.io
GEOLOCATION_API_KEY=
GEOFENCING_API_URL=https://api.geofencing.example.com
GEOFENCING_API_KEY=

# =============================================================================
# SDK USAGE (for tribe services integrating with this gateway)
# =============================================================================
# 1. Install the SDK:  npm install @apicenter/sdk
# 2. Set in your service's .env:
#      APICENTER_URL=http://localhost:3000     (dev)
#      APICENTER_URL=https://api.example.com  (prod)
#      MY_TRIBE_SECRET=<secret-from-registry>
# 3. Use:
#      import { TribeClient } from '@apicenter/sdk';
#      const client = new TribeClient({
#        gatewayUrl: process.env.APICENTER_URL,
#        tribeId:    'my-service',
#        secret:     process.env.MY_TRIBE_SECRET,
#      });
#      await client.authenticate();
#      const data = await client.callService('user-service', '/users/123');
