{
  "name": "@apicenter/gateway",
  "version": "1.0.0",
  "description": "APICenter \u2014 single centralized API gateway. 3-container HA deployment behind NGINX round-robin load balancer. All tribe-to-tribe and external API traffic routes through here.",
  "main": "./dist/sdk/TribeClient.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "dev": "nest start --watch",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./tests/jest-e2e.json",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f nginx api-center-1 api-center-2 api-center-3",
    "vault:init": "docker exec -it vault vault secrets enable -path=secret kv-v2 && docker exec -it vault vault secrets enable transit && docker exec -it vault vault write -f transit/keys/api-center-signing type=rsa-2048 && echo Vault initialized",
    "vault:put-keys": "docker exec -it vault vault kv put secret/api-center/dev jwt_private_key=\"$(openssl genrsa 2048)\" jwt_public_key=\"$(openssl rsa -pubout 2>/dev/null)\"",
    "build:sdk": "nest build && echo SDK built to dist/sdk/TribeClient.js",
    "docker:scale-check": "docker-compose ps",
    "sdk:publish": "npm run build:sdk && npm publish --access public",
    "sdk:pack": "npm run build:sdk && npm pack",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1000.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/terminus": "^10.2.0",
    "@nestjs/throttler": "^6.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-jaeger": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.0",
    "ioredis": "^5.10.0",
    "jose": "^6.2.1",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.14.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "exports": {
    ".": "./dist/sdk/TribeClient.js",
    "./sdk": "./dist/sdk/TribeClient.js"
  },
  "types": "./dist/sdk/TribeClient.d.ts",
  "files": [
    "dist/sdk",
    "README.md"
  ]
}